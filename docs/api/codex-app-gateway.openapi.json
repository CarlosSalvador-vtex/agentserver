{
  "openapi": "3.0.0",
  "info": {
    "description": "Public REST surface of codex-app-gateway: submit codex\nturns from external integrators via a workspace-scoped\nbearer API key. The WS endpoint at \"/\" is not part of\nthis spec — it follows codex's --remote protocol.",
    "title": "codex-app-gateway API",
    "contact": {},
    "version": "0.1.0"
  },
  "paths": {
    "/api/turns": {
      "post": {
        "security": [
          {
            "WorkspaceAPIKey": []
          },
          {
            "InternalSecret": []
          }
        ],
        "description": "On success, returns either {turn} (codex's raw Turn JSON) or {transport} (a structured transport error). threadId is always populated — when omitted on input, a new thread is created and its id returned. timeoutMs defaults to 300000 (5 minutes) when omitted. Bearer auth requires the `turns:submit` scope; X-Internal-Secret bypasses the scope check.",
        "tags": [
          "Turns"
        ],
        "summary": "Submit a codex turn",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TurnAPIRequest"
              }
            }
          },
          "description": "Turn submission",
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TurnAPIResponse"
                }
              }
            }
          },
          "400": {
            "description": "invalid json / workspaceId required / params required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "403": {
            "description": "api key not authorized for workspace / missing scope: turns:submit",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "InternalSecret": {
        "description": "Pre-shared secret for in-cluster RPC. Not for public consumers.",
        "type": "apiKey",
        "name": "X-Internal-Secret",
        "in": "header"
      },
      "WorkspaceAPIKey": {
        "description": "Bearer prefix required. Mint via agentserver's POST /api/workspaces/{wid}/api-keys.",
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    },
    "schemas": {
      "TurnAPIRequest": {
        "type": "object",
        "required": [
          "params",
          "workspaceId"
        ],
        "properties": {
          "params": {
            "type": "object"
          },
          "threadId": {
            "type": "string",
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "example": 300000
          },
          "workspaceId": {
            "type": "string",
            "example": "ws-7e7a4f6c"
          }
        }
      },
      "TurnAPIResponse": {
        "type": "object",
        "required": [
          "threadId"
        ],
        "properties": {
          "threadId": {
            "type": "string"
          },
          "transport": {
            "allOf": [
              {
                "$ref": "#/components/schemas/TurnTransportError"
              }
            ],
            "nullable": true
          },
          "turn": {
            "type": "object"
          }
        }
      },
      "TurnTransportError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "brokerTimeout"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
